{
  "version": 2,

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/photo-editor",
      "destination": "/photo-editor.html"
    },
    {
      "source": "/compress",
      "destination": "/compress.html"
    },
    {
      "source": "/resize",
      "destination": "/resize.html"
    },
    {
      "source": "/convert",
      "destination": "/convert.html"
    },
    {
      "source": "/watermark",
      "destination": "/watermark.html"
    },
    {
      "source": "/remove-bg",
      "destination": "/remove-bg.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}