{
  "version": 2,
  "rewrites": [
    { "source": "/remove-bg", "destination": "/remove-bg.html" },
    { "source": "/photo-editor", "destination": "/photo-editor.html" },
    { "source": "/compress", "destination": "/compress.html" },
    { "source": "/resize", "destination": "/resize.html" },
    { "source": "/convert", "destination": "/convert.html" },
    { "source": "/watermark", "destination": "/watermark.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" }
      ]
    }
  ]
}