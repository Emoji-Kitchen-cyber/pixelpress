{
  "version": 2,
  "rewrites": [
    { "source": "/photo-editor", "destination": "/photo-editor.html" },
    { "source": "/compress", "destination": "/compress.html" },
    { "source": "/resize", "destination": "/resize.html" },
    { "source": "/convert", "destination": "/convert.html" },
    { "source": "/watermark", "destination": "/watermark.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}